  keywords = {Bayesian inference,Gibbs sampling,Markov chain Monte Carlo,Mean field variational Bayes},
  file = {/Users/steven/Zotero/storage/IGHBKR7R/Huang and Wand - 2013 - Simple Marginally Noninformative Prior Distributions for Covariance Matrices.pdf}
